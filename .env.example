# MCP Server — variáveis de ambiente
# Copie para .env e preencha os valores

# Caminho para o arquivo de contexto de negócio
BUSINESS_CONTEXT_PATH=./business_context.json

# Caminho para o banco de dados SQLite da knowledge base
KB_DATABASE_PATH=./data/knowledge_base.db

# (Opcional) Chave da API Anthropic — só necessária se integrar com Claude via SDK
# ANTHROPIC_API_KEY=sk-ant-...

# (Opcional) Número máximo de resultados na busca da KB
KB_MAX_RESULTS=5
